# 复制为 .env.local 供 vercel dev 使用；生产环境在 Vercel 项目 → Settings → Environment Variables 填写。
# 两个都要设才会启用站点密码；留空则不启用门禁。

SITE_PASSWORD=请改成强密码
# 随机串即可，例如 PowerShell: [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
SITE_AUTH_SECRET=

# Finnhub REST 报价（api/finnhub-quote）；勿写入前端 HTML
FINNHUB_TOKEN=

# Twelve Data 美股主报价（api/stock-price）；注册 https://twelvedata.com
TWELVE_DATA_KEY=
